<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>极简待办</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    background: #F5F7FA;
    color: #333;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    padding: 40px 16px;
  }
  .app {
    width: 100%;
    max-width: 600px;
  }
  h1 {
    font-size: 28px;
    font-weight: 700;
    color: #165DFF;
    margin-bottom: 24px;
    text-align: center;
  }
  .input-wrap {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }
  #todo-input {
    flex: 1;
    padding: 12px 16px;
    font-size: 16px;
    border: 2px solid #e0e5ec;
    border-radius: 10px;
    outline: none;
    transition: border-color .2s;
    background: #fff;
  }
  #todo-input:focus {
    border-color: #165DFF;
  }
  #todo-input::placeholder {
    color: #bbb;
  }
  #add-btn {
    padding: 12px 20px;
    font-size: 16px;
    background: #165DFF;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background .2s, transform .1s;
    white-space: nowrap;
  }
  #add-btn:hover {
    background: #0e42d2;
  }
  #add-btn:active {
    transform: scale(0.96);
  }
  .list {
    list-style: none;
  }
  .todo-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    margin-bottom: 8px;
    background: #fff;
    border-radius: 10px;
    transition: background .15s;
  }
  .todo-item:hover {
    background: #f0f4ff;
  }
  .checkbox {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border: 2px solid #d0d5dd;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
  }
  .checkbox:hover {
    border-color: #165DFF;
  }
  .checkbox.done {
    background: #165DFF;
    border-color: #165DFF;
  }
  .checkbox.done::after {
    content: "✓";
    color: #fff;
    font-size: 14px;
    font-weight: 700;
  }
  .todo-text {
    flex: 1;
    font-size: 15px;
    word-break: break-all;
    transition: color .2s;
  }
  .todo-text.done {
    color: #bbb;
    text-decoration: line-through;
  }
  .delete-btn {
    flex-shrink: 0;
    padding: 6px 12px;
    font-size: 13px;
    color: #f53f3f;
    background: transparent;
    border: 1px solid #fcc;
    border-radius: 6px;
    cursor: pointer;
    transition: all .2s;
  }
  .delete-btn:hover {
    background: #f53f3f;
    color: #fff;
  }
  .delete-btn:active {
    transform: scale(0.94);
  }
  .stats {
    text-align: center;
    margin-top: 20px;
    font-size: 14px;
    color: #999;
  }
  .empty-hint {
    text-align: center;
    color: #ccc;
    font-size: 15px;
    margin-top: 60px;
  }
</style>
</head>
<body>
<div class="app">
  <h1>待办清单</h1>
  <div class="input-wrap">
    <input id="todo-input" type="text" placeholder="添加待办事项..." autofocus>
    <button id="add-btn">添加</button>
  </div>
  <ul class="list" id="todo-list"></ul>
  <div class="stats" id="stats">已完成 0 / 总数 0</div>
</div>

<script>
(function () {
  var STORAGE_KEY = 'todo-mvp-data';

  /* ===== 数据操作 ===== */
  function loadTodos() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch (e) {
      return [];
    }
  }

  function saveTodos(todos) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
  }

  /* ===== DOM 引用 ===== */
  var input = document.getElementById('todo-input');
  var addBtn = document.getElementById('add-btn');
  var listEl = document.getElementById('todo-list');
  var stats = document.getElementById('stats');

  /* ===== 渲染与统计 ===== */
  function render() {
    var todos = loadTodos();
    listEl.innerHTML = '';
    var doneCount = 0;

    todos.forEach(function (todo, idx) {
      if (todo.done) doneCount++;

      var li = document.createElement('li');
      li.className = 'todo-item';

      // 复选框
      var cb = document.createElement('span');
      cb.className = 'checkbox' + (todo.done ? ' done' : '');
      cb.title = todo.done ? '取消完成' : '标记完成';
      cb.addEventListener('click', function () { toggleTodo(idx); });
      li.appendChild(cb);

      // 文字
      var text = document.createElement('span');
      text.className = 'todo-text' + (todo.done ? ' done' : '');
      text.textContent = todo.text;
      li.appendChild(text);

      // 删除按钮
      var del = document.createElement('button');
      del.className = 'delete-btn';
      del.textContent = '删除';
      del.addEventListener('click', function () { deleteTodo(idx); });
      li.appendChild(del);

      listEl.appendChild(li);
    });

    stats.textContent = '已完成 ' + doneCount + ' / 总数 ' + todos.length;
  }

  /* ===== 增删改 ===== */
  function addTodo(text) {
    var trimmed = text.trim();
    if (!trimmed) return;
    var todos = loadTodos();
    todos.push({ text: trimmed, done: false });
    saveTodos(todos);
    render();
  }

  function toggleTodo(idx) {
    var todos = loadTodos();
    if (idx < 0 || idx >= todos.length) return;
    todos[idx].done = !todos[idx].done;
    saveTodos(todos);
    render();
  }

  function deleteTodo(idx) {
    var todos = loadTodos();
    if (idx < 0 || idx >= todos.length) return;
    todos.splice(idx, 1);
    saveTodos(todos);
    render();
  }

  /* ===== 事件绑定 ===== */
  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      addTodo(input.value);
      input.value = '';
    }
  });

  addBtn.addEventListener('click', function () {
    addTodo(input.value);
    input.value = '';
    input.focus();
  });

  /* ===== 初始化 ===== */
  render();
})();
</script>
</body>
</html>
